# Copy to backend/.env and adjust as needed. All values are optional in development.

# SQLite (default) or PostgreSQL, e.g. postgresql+psycopg2://user:pass@host/codelab
# DATABASE_URL=sqlite:///./codelab.db

# Signs classroom session tokens. MUST be set to a long random value in production.
# SECRET_KEY=change-me-to-a-long-random-string

# How long a classroom session lasts before the PIN is required again.
# TOKEN_TTL_HOURS=12

# Comma-separated list of allowed frontend origins.
# CORS_ORIGINS=http://localhost:5173
